modules = ["nodejs-20", "web", "java-graalvm22.3"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd Point-Of-Sale-System/backend && node -r dotenv/config dist/index.js dotenv_config_path=.env"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd Point-Of-Sale-System && npm run dev --prefix pos-frontend"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "cd Point-Of-Sale-System/backend && node -r dotenv/config dist/index.js dotenv_config_path=.env & cd Point-Of-Sale-System/pos-frontend && npx vite preview --host 0.0.0.0 --port 5000"]
build = ["bash", "-c", "cd Point-Of-Sale-System/backend && npm install && npm run build && cd ../pos-frontend && npm install && npm run build"]
